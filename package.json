{
  "name": "news-dashboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:migrate": "pnpm exec tsx scripts/apply-migration.ts db/migrations/001_initial_schema.sql",
    "db:migrate:dedupe": "pnpm exec tsx scripts/apply-migration.ts db/migrations/002_manual_ingest_dedupe.sql",
    "db:migrate:ingestion-runs": "pnpm exec tsx scripts/apply-migration.ts db/migrations/003_ingestion_runs.sql",
    "db:migrate:stock-cache": "pnpm exec tsx scripts/apply-migration.ts db/migrations/004_stock_price_cache.sql",
    "db:migrate:analysis-history": "pnpm exec tsx scripts/apply-migration.ts db/migrations/005_analysis_history.sql",
    "db:clear:events": "pnpm exec tsx scripts/clear-events.ts",
    "db:seed:events": "pnpm exec tsx scripts/seed-events.ts",
    "db:check:events": "pnpm exec tsx scripts/check-seeded-events.ts",
    "db:seed:symbols": "pnpm exec tsx scripts/seed-symbol-universe.ts",
    "db:check:symbols": "pnpm exec tsx scripts/check-symbol-universe.ts",
    "db:link:event-symbols": "pnpm exec tsx scripts/link-event-symbols.ts",
    "db:check:event-symbols": "pnpm exec tsx scripts/check-event-symbol-links.ts"
  },
  "dependencies": {
    "next": "^15.2.4",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-globe.gl": "^2.37.0",
    "react-simple-maps": "^3.0.0",
    "three": "^0.183.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/react-simple-maps": "^3.0.6",
    "@types/topojson-client": "^3.1.5",
    "dotenv": "^17.3.1",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2"
  }
}
